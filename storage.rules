rules_version = '2';

// Firebase Storage rules for the job tracker.
// Photos, receipts and documents are uploaded here; only signed-in users
// (Firebase Auth) can read or write. This mirrors the Realtime Database
// model — access requires authentication. Tighten further per-company if
// needed, but auth-gated read/write matches how the app signs users in.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
