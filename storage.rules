rules_version = '2';

// Firebase Storage rules for the job tracker.
// Photos, receipts and documents are uploaded under:
//   {companyNamespace}/jobs/{jobId}/{photos|docs|receipts}/{file}
//
// ───────────────────────────────────────────────────────────────────────────
// SECURITY LIMITATION — READ THIS BEFORE RELYING ON THESE RULES
//
// Storage rules CANNOT read the Realtime Database, so they cannot see a user's
// role or company (those live at /users/{uid} in RTDB). That means these rules
// alone CANNOT enforce per-company isolation: any approved, signed-in user can
// still read/write/delete files belonging to ANY company.
//
// The checks below are "interim hardening" only. They:
//   • require a real (non-anonymous) signed-in account,
//   • keep the company namespace + path shape constrained,
//   • require photo uploads to be images or videos, and
//   • deny everything outside the known job-asset paths.
//
// They DO NOT, and cannot, stop a signed-in user of company A from reading
// company B's files. Closing that gap requires one of:
//   1. Firebase Auth custom claims (company/role stamped on the token by an
//      admin/Cloud Function) gated here as request.auth.token.company == company, or
//   2. a server-side upload/download broker that checks the caller's RTDB role.
// Until one of those ships, treat cross-company file confidentiality as NOT
// enforced at the Storage layer.
// ───────────────────────────────────────────────────────────────────────────
service firebase.storage {
  match /b/{bucket}/o {
    // A real signed-in user. Anonymous auth is rejected: the app only uses
    // email/password sign-in, so an anonymous token is never legitimate and
    // would otherwise be a free pass for drive-by access.
    function signedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function validCompany(company) {
      return company.matches('^[a-z0-9_-]{2,24}(_dev)?$');
    }

    function validKind(kind) {
      return kind.matches('^(photos|docs|receipts)$');
    }

    // Document/receipt payloads: images, PDFs, plain text/CSV, Office files, or
    // an unknown-binary fallback (some browsers upload files as octet-stream).
    function docType() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'text/plain'
        || request.resource.contentType == 'text/csv'
        || request.resource.contentType == 'application/vnd.ms-excel'
        || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
        || request.resource.contentType == 'application/octet-stream';
    }

    // The photos/ path holds job media: client re-encoded images (image/jpeg)
    // and short videos uploaded raw (the browser can't transcode video). Both
    // are constrained by content type so the folder can't stash arbitrary binaries.
    function typeOkFor(kind) {
      return kind == 'photos'
        ? (request.resource.contentType.matches('image/.*')
           || request.resource.contentType.matches('video/.*'))
        : docType();
    }

    // Videos are much larger than the ~150 KB client-compressed photos, so the
    // photos/ path gets extra headroom. Docs/receipts stay at the tighter limit.
    function sizeCapFor(kind) {
      return kind == 'photos' ? 60 * 1024 * 1024 : 25 * 1024 * 1024;
    }

    function reasonableUpload(kind) {
      return request.resource != null
        && request.resource.size < sizeCapFor(kind)
        && typeOkFor(kind);
    }

    function validLogoKind(kind) {
      return kind.matches('^(app|invoice)$');
    }

    function validLogoName(fileName) {
      return fileName.matches('^[A-Za-z0-9._-]{1,120}$');
    }

    function reasonableLogoUpload() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{company}/jobs/{jobId}/{kind}/{fileName} {
      allow read: if signedIn() && validCompany(company) && validKind(kind);
      allow create, update: if signedIn() && validCompany(company) && validKind(kind) && reasonableUpload(kind);
      allow delete: if signedIn() && validCompany(company) && validKind(kind);
    }

    match /{company}/logos/{kind}/{fileName} {
      allow read: if signedIn() && validCompany(company) && validLogoKind(kind) && validLogoName(fileName);
      allow create, update: if signedIn() && validCompany(company) && validLogoKind(kind) && validLogoName(fileName) && reasonableLogoUpload();
      allow delete: if signedIn() && validCompany(company) && validLogoKind(kind) && validLogoName(fileName);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
