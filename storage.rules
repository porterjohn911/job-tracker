rules_version = '2';

// Firebase Storage rules for the job tracker.
// Photos, receipts and documents are uploaded under:
//   {companyNamespace}/jobs/{jobId}/{photos|docs|receipts}/{file}
//
// Storage rules cannot read Realtime Database role records. Per-company role
// enforcement here requires custom auth claims or a server-side upload broker.
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function validCompany(company) {
      return company.matches('^(wfs|mhs|nlr)(_dev)?$');
    }

    function reasonableUpload() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'text/plain'
          || request.resource.contentType == 'text/csv'
          || request.resource.contentType == 'application/vnd.ms-excel'
          || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
          || request.resource.contentType == 'application/octet-stream'
        );
    }

    match /{company}/jobs/{jobId}/{kind}/{fileName} {
      allow read: if signedIn() && validCompany(company) && kind.matches('^(photos|docs|receipts)$');
      allow create, update: if signedIn() && validCompany(company) && kind.matches('^(photos|docs|receipts)$') && reasonableUpload();
      allow delete: if signedIn() && validCompany(company) && kind.matches('^(photos|docs|receipts)$');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
