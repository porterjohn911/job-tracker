{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && ( (auth.uid === $uid && !data.exists() && (!data.parent().exists() || newData.child('role').val() === 'pending')) || root.child('users').child(auth.uid).child('role').val() === 'owner' )"
      }
    },

    "$company": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",

      "jobs": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$jobId": {
          ".validate": "newData.hasChildren(['id', 'name']) && newData.child('id').isString() && newData.child('id').val() === $jobId && newData.child('name').isString()"
        }
      },

      "activity": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$activityId": {
          ".validate": "newData.hasChildren(['action', 'time']) && newData.child('action').isString() && newData.child('time').isNumber()"
        }
      },

      "members": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')"
      },

      "referrals": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$referralId": {
          ".validate": "newData.hasChildren(['id']) && newData.child('id').isString() && newData.child('id').val() === $referralId"
        }
      },

      "customers": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$customerId": {
          ".validate": "newData.hasChildren(['id']) && newData.child('id').isString() && newData.child('id').val() === $customerId"
        }
      },

      "time": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$entryId": {
          ".validate": "newData.hasChildren(['id', 'member', 'start']) && newData.child('id').isString() && newData.child('id').val() === $entryId && newData.child('member').isString() && newData.child('start').isNumber()"
        }
      },

      "payrates": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')"
      },

      "transactions": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner'",
        "$transactionId": {
          ".validate": "newData.hasChildren(['id', 'date', 'description', 'amount']) && newData.child('id').isString() && newData.child('id').val() === $transactionId && newData.child('date').isString() && newData.child('description').isString() && newData.child('amount').isNumber()"
        }
      },

      "$other": {
        ".validate": false
      }
    }
  }
}
