{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && ( (auth.uid === $uid && !data.exists() && (!data.parent().exists() || newData.child('role').val() === 'pending')) || root.child('users').child(auth.uid).child('role').val() === 'owner' )"
      }
    },

    "owner_schedule": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
      "$id": {
        ".validate": "newData.hasChildren(['id', 'date', 'title']) && newData.child('id').isString() && newData.child('id').val() === $id && newData.child('date').isString() && newData.child('title').isString()"
      }
    },

    "companies": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner'",
      "$companyId": {
        ".validate": "newData.hasChildren(['id', 'ns', 'label']) && newData.child('id').isString() && newData.child('id').val() === $companyId && newData.child('id').val().matches(/^[a-z0-9_-]{2,24}$/) && newData.child('ns').isString() && newData.child('ns').val().matches(/^[a-z0-9_-]{2,24}$/) && newData.child('label').isString() && newData.child('label').val().matches(/^.{1,80}$/) && (!newData.child('tag').exists() || (newData.child('tag').isString() && newData.child('tag').val().matches(/^.{0,120}$/))) && (!newData.child('active').exists() || newData.child('active').isBoolean()) && (!newData.child('createdAt').exists() || newData.child('createdAt').isNumber()) && (!newData.child('updatedAt').exists() || newData.child('updatedAt').isNumber()) && (!newData.child('appLogoUrl').exists() || newData.child('appLogoUrl').isString()) && (!newData.child('invoiceLogoUrl').exists() || newData.child('invoiceLogoUrl').isString()) && (!newData.child('appLogoPath').exists() || (newData.child('appLogoPath').isString() && newData.child('appLogoPath').val().matches(/^[a-z0-9_-]{2,24}(_dev)?\\/logos\\/app\\/[A-Za-z0-9._-]{1,120}$/))) && (!newData.child('invoiceLogoPath').exists() || (newData.child('invoiceLogoPath').isString() && newData.child('invoiceLogoPath').val().matches(/^[a-z0-9_-]{2,24}(_dev)?\\/logos\\/invoice\\/[A-Za-z0-9._-]{1,120}$/)))"
      }
    },

    "api_keys": {
      ".read": false,
      ".write": false
    },

    "$company": {
      "jobs": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$jobId": {
          ".validate": "newData.hasChildren(['id', 'name']) && newData.child('id').isString() && newData.child('id').val() === $jobId && newData.child('name').isString()"
        }
      },

      "activity": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$activityId": {
          ".validate": "newData.hasChildren(['action', 'time']) && newData.child('action').isString() && newData.child('time').isNumber()"
        }
      },

      "members": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')"
      },

      "referrals": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$referralId": {
          ".validate": "newData.hasChildren(['id']) && newData.child('id').isString() && newData.child('id').val() === $referralId"
        }
      },

      "customers": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$customerId": {
          ".validate": "newData.hasChildren(['id']) && newData.child('id').isString() && newData.child('id').val() === $customerId"
        }
      },

      "time": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$entryId": {
          ".validate": "newData.hasChildren(['id', 'member', 'start']) && newData.child('id').isString() && newData.child('id').val() === $entryId && newData.child('member').isString() && newData.child('start').isNumber()"
        }
      },

      "payrates": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager')"
      },

      "transactions": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner'",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'owner'",
        "$transactionId": {
          ".validate": "newData.hasChildren(['id', 'date', 'description', 'amount']) && newData.child('id').isString() && newData.child('id').val() === $transactionId && newData.child('date').isString() && newData.child('description').isString() && newData.child('amount').isNumber()"
        }
      },

      "timeoff": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$id": {
          ".validate": "newData.hasChildren(['id', 'member', 'startDate', 'status']) && newData.child('id').isString() && newData.child('id').val() === $id && newData.child('member').isString() && newData.child('startDate').isString() && newData.child('status').isString()"
        }
      },

      "receipts": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('company').val() === $company || $company === root.child('users').child(auth.uid).child('company').val() + '_dev')",
        "$receiptId": {
          ".validate": "newData.hasChildren(['id', 'amount']) && newData.child('id').isString() && newData.child('id').val() === $receiptId && newData.child('amount').isNumber()"
        }
      },

      "$other": {
        ".validate": false
      }
    }
  }
}
